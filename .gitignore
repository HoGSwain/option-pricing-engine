# --- Python bytecode / caches ---
__pycache__/
*.py[cod]
*$py.class

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Packaging / build artifacts ---
build/
dist/
*.egg-info/
*.egg
.eggs/

# --- Test / coverage artifacts ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.cache/

# --- Type checker / linter caches ---
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Notebook-generated outputs (regenerable; the executed .ipynb is self-contained) ---
notebooks/data/
notebooks/reports/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
